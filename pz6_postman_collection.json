{
  "info": {
    "name": "PZ6 — CSRF/XSS/Secure Cookies",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "1. Login (создание сессии)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/login",
          "host": ["{{base_url}}"],
          "path": ["login"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Redirect to /profile', function () {",
              "    pm.expect(pm.response.code).to.be.oneOf([200, 302]);",
              "});",
              "",
              "// Extract CSRF token from profile page HTML",
              "var html = pm.response.text();",
              "var match = html.match(/name=\"csrf_token\"\\s+value=\"([^\"]+)\"/);",
              "if (match) {",
              "    pm.collectionVariables.set('csrf_token', match[1]);",
              "    console.log('CSRF token saved: ' + match[1]);",
              "}"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "followRedirects": true
      }
    },
    {
      "name": "2. Profile GET (форма + CSRF-токен)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/profile",
          "host": ["{{base_url}}"],
          "path": ["profile"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Contains CSRF token', function () {",
              "    pm.expect(pm.response.text()).to.include('csrf_token');",
              "});",
              "",
              "var html = pm.response.text();",
              "var match = html.match(/name=\"csrf_token\"\\s+value=\"([^\"]+)\"/);",
              "if (match) {",
              "    pm.collectionVariables.set('csrf_token', match[1]);",
              "    console.log('CSRF token: ' + match[1]);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "3. Profile POST — INVALID CSRF (→ 403)",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/profile",
          "host": ["{{base_url}}"],
          "path": ["profile"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "csrf_token", "value": "wrong-token-12345" },
            { "key": "name", "value": "Hacker" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('CSRF rejected — 403 Forbidden', function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "",
              "pm.test('Error message', function () {",
              "    pm.expect(pm.response.text()).to.include('invalid csrf token');",
              "});"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "followRedirects": false
      }
    },
    {
      "name": "4. Profile POST — VALID CSRF (имя: Иван)",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/profile",
          "host": ["{{base_url}}"],
          "path": ["profile"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "csrf_token", "value": "{{csrf_token}}" },
            { "key": "name", "value": "Иван" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Redirect to /hello (302)', function () {",
              "    pm.response.to.have.status(302);",
              "});"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "followRedirects": false
      }
    },
    {
      "name": "5. Hello GET (приветствие: Иван)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/hello",
          "host": ["{{base_url}}"],
          "path": ["hello"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Shows name Иван', function () {",
              "    pm.expect(pm.response.text()).to.include('Иван');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "6. Profile GET (обновить CSRF перед XSS-тестом)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/profile",
          "host": ["{{base_url}}"],
          "path": ["profile"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "var html = pm.response.text();",
              "var match = html.match(/name=\"csrf_token\"\\s+value=\"([^\"]+)\"/);",
              "if (match) {",
              "    pm.collectionVariables.set('csrf_token', match[1]);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "7. Profile POST — XSS payload в имени",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/profile",
          "host": ["{{base_url}}"],
          "path": ["profile"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "csrf_token", "value": "{{csrf_token}}" },
            { "key": "name", "value": "<script>alert('xss')</script>" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Redirect (302)', function () {",
              "    pm.response.to.have.status(302);",
              "});"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "followRedirects": false
      }
    },
    {
      "name": "8. Hello GET — XSS экранирован",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/hello",
          "host": ["{{base_url}}"],
          "path": ["hello"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Script tag is escaped (not raw)', function () {",
              "    var body = pm.response.text();",
              "    pm.expect(body).to.not.include('<script>');",
              "    pm.expect(body).to.include('&lt;script&gt;');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "9. Comments GET (список + получить CSRF)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/comments",
          "host": ["{{base_url}}"],
          "path": ["comments"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "var html = pm.response.text();",
              "var match = html.match(/name=\"csrf_token\"\\s+value=\"([^\"]+)\"/);",
              "if (match) {",
              "    pm.collectionVariables.set('csrf_token', match[1]);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "10. Comments POST — добавить комментарий",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/comments",
          "host": ["{{base_url}}"],
          "path": ["comments"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "csrf_token", "value": "{{csrf_token}}" },
            { "key": "text", "value": "Обычный комментарий" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Redirect (302)', function () {",
              "    pm.response.to.have.status(302);",
              "});"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "followRedirects": false
      }
    },
    {
      "name": "11. Comments GET — обновить CSRF",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/comments",
          "host": ["{{base_url}}"],
          "path": ["comments"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Comment visible', function () {",
              "    pm.expect(pm.response.text()).to.include('Обычный комментарий');",
              "});",
              "",
              "var html = pm.response.text();",
              "var match = html.match(/name=\"csrf_token\"\\s+value=\"([^\"]+)\"/);",
              "if (match) {",
              "    pm.collectionVariables.set('csrf_token', match[1]);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "12. Comments POST — XSS в комментарии",
      "request": {
        "method": "POST",
        "url": {
          "raw": "{{base_url}}/comments",
          "host": ["{{base_url}}"],
          "path": ["comments"]
        },
        "header": [
          {
            "key": "Content-Type",
            "value": "application/x-www-form-urlencoded"
          }
        ],
        "body": {
          "mode": "urlencoded",
          "urlencoded": [
            { "key": "csrf_token", "value": "{{csrf_token}}" },
            { "key": "text", "value": "<b>bold</b><script>alert('hack')</script>" }
          ]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Redirect (302)', function () {",
              "    pm.response.to.have.status(302);",
              "});"
            ]
          }
        }
      ],
      "protocolProfileBehavior": {
        "followRedirects": false
      }
    },
    {
      "name": "13. Comments GET — XSS экранирован",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/comments",
          "host": ["{{base_url}}"],
          "path": ["comments"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status 200', function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test('Script tag escaped in comments', function () {",
              "    var body = pm.response.text();",
              "    pm.expect(body).to.not.include('<script>alert');",
              "    pm.expect(body).to.include('&lt;script&gt;');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "14. Logout",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/logout",
          "host": ["{{base_url}}"],
          "path": ["logout"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Redirect to /login', function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "15. Profile после logout (→ 401)",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/profile",
          "host": ["{{base_url}}"],
          "path": ["profile"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Unauthorized after logout', function () {",
              "    pm.response.to.have.status(401);",
              "});"
            ]
          }
        }
      ]
    }
  ]
}
